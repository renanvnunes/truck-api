{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": ["FromLogContext"],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/docs%' or RequestPath like '/openapi%' or RequestPath = '/'"
        }
      }
    ]
  },
  "RateLimit": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    }
  },
  "MongoDB": {
    "Database": "truck_audit"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "TruckApi",
    "Audience": "TruckApi",
    "ExpirationHours": 1,
    "RefreshTokenExpirationDays": 7
  }
}
