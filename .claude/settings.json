{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; echo \"$f\" | grep -q '\\.cs$' && dotnet build /home/renan/Documentos/Renan/truck/TruckApi/TruckApi.csproj --no-restore -v q; } 2>/dev/null || true",
            "statusMessage": "Building TruckApi...",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(dotnet build *)",
      "Bash(dotnet add *)",
      "Bash(find /home/renan/.nuget/packages/nanoid -name \"*.dll\" | head -5)",
      "Read(//home/renan/.nuget/packages/nanoid/**)",
      "Bash(dotnet script *)",
      "Bash(xargs cat)",
      "Bash(dotnet restore *)",
      "Bash(dotnet remove *)",
      "Bash(find ~/.nuget -path \"*Scalar.AspNetCore*2.14*\" -name \"*.cs\" | head -5)",
      "Read(//home/renan/.nuget/**)",
      "Bash(dotnet-reflect /home/renan/.nuget/packages/scalar.aspnetcore/2.14.14/lib/net10.0/Scalar.AspNetCore.dll)",
      "Bash(grep -E \"^[A-Z][a-zA-Z]+$\")",
      "Bash(dotnet fsi *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://application-api-dotnet.nuykhx.easypanel.host/docs\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://application-api-dotnet.nuykhx.easypanel.host/openapi/v1.json\")"
    ]
  }
}
